{
  "name": "visual-regression-tcc",
  "version": "1.0.0",
  "description": "Comparativo de técnicas de regressão visual: pixel-a-pixel, SSIM e regiões",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "capture": "node tests/capture.js",
    "compare": "node tests/compare.js",
    "evaluate": "node tests/evaluate.js",
    "report": "node tests/report.js",
    "update-baselines": "node scripts/update-baselines.js",
    "ci": "node tests/capture.js && node tests/compare.js && node tests/report.js",
    "review:build": "cd packages/pixelguard-review && npx vite build",
    "review:start": "node packages/pixelguard-review/server/index.js",
    "review": "npm run review:build && npm run review:start"
  },
  "dependencies": {
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "^6.4.0",
    "@mui/material": "^6.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "pixelmatch": "^6.0.0",
    "playwright": "^1.49.0",
    "pngjs": "^7.0.0",
    "vite": "^6.0.0"
  }
}
